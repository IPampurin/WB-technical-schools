## переменные сервера и api

# имя службы (контейнера) в докере
SERVICE_HOST_NAME=0.0.0.0
# порт хоста, на котором работает сервис
SERVICE_PORT=8081
# переулючатель режима логов
GIN_MODE=debug

## переменные сервиса

# ширина миниатюры по умолчанию
WIDTH_THUMBNAIL=150
# высота миниатюры по умолчанию
HEIGHT_THUMBNAIL=200

## переменные базы данных

# имя службы (контейнера) в докере
DB_HOST_NAME=postgres
# порт, на котором сидит база данных
DB_PORT=5432
# имя базы данных
DB_NAME=postgres
# пароль базы данных
DB_PASSWORD=postgres
# имя пользователя базы данных
DB_USER=postgres

## переменные S3 хранилища

# эндпоинт MinIO (адрес и порт)
S3_ENDPOINT=minio:9000
# ключ доступа (логин)
S3_ACCESS_KEY=minioadmin
# секретный ключ (пароль)
S3_SECRET_KEY=minioadmin
# имя бакета для хранения изображений
S3_BUCKET=images
# использовать SSL (true/false) — обычно false для локальной разработки
S3_USE_SSL=false

## переменные Kafka

# номер порта для кафки
KAFKA_PORT_NUM=9092
# имя кафки на хосте
KAFKA_HOST_NAME=kafka
# хост имя порт кафки
KAFKA_BROKERS=kafka:9092
# имя топика для задач
KAFKA_INPUT_TOPIC=image-tasks
# имя топика для результатов
KAFKA_OUTPUT_TOPIC=image-results
# имя консумер группы
KAFKA_CONSUMER_GROUP=image-processor-manager
