## переменные сервера и api

# имя службы (контейнера) в докере
SERVICE_HOST_NAME=0.0.0.0
# порт хоста, на котором работает сервис
SERVICE_PORT=8081
# переулючатель режима логов
GIN_MODE=debug

## переменные базы данных

# имя службы (контейнера) в докере
DB_HOST_NAME=postgres
# порт, на котором сидит база данных
DB_PORT=5432
# имя базы данных
DB_NAME=postgres
# пароль базы данных
DB_PASSWORD=postgres
# имя пользователя базы данных
DB_USER=postgres

## переменные ZSET

# имя службы (контейнера) в сети докера
REDIS_HOST_NAME=redis
# порт, на котором сидит Redis
REDIS_PORT=6379
# пароль от БД Redis
REDIS_PASSWORD=
# номер БД Redis
REDIS_DB=0
# ключ ZSET для просроченных броней
ZSET_OVERDUE_KEY=bookings
# интервал проверки (в секундах)
ZSET_CHECK_INTERVAL=1s
# стратегия повторов чтения
REDIS_READ_RETRY_ATTEMPTS=3
REDIS_READ_RETRY_DELAY=100ms
REDIS_READ_RETRY_BACKOFF=2.0

## переменные брокера

# имя службы (контейнера) в докере
RABBIT_HOST_NAME=rabbitMQ
# порт, на котором сидит RabbitMQ
RABBIT_PORT=5672
# имя пользователя RabbitMQ
RABBIT_USER=rabbitMQ
# пароль от RabbitMQ
RABBIT_PASSWORD=rabbit
# virtual host, отдельная «база данных» для очередей, по умолчанию /
RABBIT_VHOST=/
# имя очереди сервиса
RABBIT_QUEUE=bookingQueue
# exchange и routing key
RABBIT_EXCHANGE=bookingExchange
RABBIT_ROUTING_KEY=booking
# технические параметры подключения
RABBIT_CONNECTION_NAME=eventbooker
RABBIT_CONNECT_TIMEOUT=5s
RABBIT_HEARTBEAT=10s
# единая стратегия повторов (и для публикации, и для потребления)
RABBIT_RETRY_ATTEMPTS=3
RABBIT_RETRY_DELAY=3s
RABBIT_RETRY_BACKOFF=2.0

